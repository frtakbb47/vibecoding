# Server port (Render sets PORT automatically)
PORT=3000

# REQUIRED in production: long random secret string for signing host reclaim tokens
HOST_TOKEN_SECRET=replace-with-a-long-random-secret

# Optional: set to production on hosts
NODE_ENV=production

# Optional: enable Supabase persistence (recommended for free hosting)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_TABLE=pomodoro_dual_state
